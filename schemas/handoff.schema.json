        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "task_ids": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "config_changes": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
