              "type": {
                "enum": [
                  "spec",
                  "engineering",
                  "hotfix",
                  "adr"
                ]
              },
              "module": {
                "type": "string"
              },
              "space": {
                "enum": [
                  "repo",
                  "module",
                  "global"
                ]
