                    "code": {
                      "type": "string"
                    },
                    "message": {
                      "type": "string"
                    },
                    "path": {
                      "type": "string"
                    },
                    "line": {
                      "type": "number"
                    },
                    "taskId": {
                      "type": "string"
                    },
                    "stepId": {
                      "type": "string"
                    }
