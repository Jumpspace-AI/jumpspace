          "audit_warnings": {
            "type": "number"
          },
          "doctor_errors": {
            "type": "number"
          },
          "doctor_warnings": {
            "type": "number"
          },
          "doctor_suggestions": {
            "type": "number"
          },
          "mutations_returned": {
            "type": "number"
          },
          "touched_files": {
            "type": "number"
          },
          "task_ids": {
