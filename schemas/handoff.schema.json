                    "message": {
                      "type": "string"
                    },
                    "taskId": {
                      "type": "string"
                    },
                    "status": {
                      "type": "string"
                    }
                  }
                }
              },
              "pending_step_ids": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "required_checks": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
