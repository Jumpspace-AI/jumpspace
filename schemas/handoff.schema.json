      "packet_version": {
        "const": 1
      },
      "generated_at": {
        "type": "string"
      },
      "status": {
        "enum": [
          "ready",
          "attention",
          "blocked"
        ]
      },
      "filters": {
        "type": "object",
        "required": [
          "limit"
