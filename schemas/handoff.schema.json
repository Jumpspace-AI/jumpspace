      "packet_version",
      "generated_at",
      "status",
      "filters",
      "summary",
      "recent_mutations",
      "last_mutation",
      "touched_files",
      "task_ids",
      "config_changes",
      "mutation_warnings",
      "health",
      "task",
      "suggested_commands",
      "schemas"
    ],
    "additionalProperties": false,
    "properties": {
