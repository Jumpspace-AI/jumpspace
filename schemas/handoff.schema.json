        "type": "object",
        "required": [
          "packet",
          "failures",
          "history",
          "doctor",
          "audit",
          "context",
          "next",
          "schema_coverage"
        ],
        "additionalProperties": false,
        "properties": {
          "packet": {
            "const": "handoff"
          },
          "failures": {
            "const": "error"
          },
          "history": {
            "const": "history"
          },
          "doctor": {
            "const": "doctor"
          },
          "audit": {
            "const": "audit"
          },
          "context": {
            "const": "context"
          },
          "next": {
            "const": "next"
          },
          "schema_coverage": {
            "const": "schema.coverage"
          }
        }
      }
    }
