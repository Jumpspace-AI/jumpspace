                  "message": {
                    "type": "string"
                  },
                  "taskId": {
                    "type": "string"
                  },
                  "status": {
                    "type": "string"
                  }
                }
              }
            },
            "dependencies": {
              "type": "array",
              "items": {
                "type": "object",
                "required": [
                  "id",
                  "title",
                  "type",
                  "status",
                  "doc",
                  "spec",
                  "code",
                  "tests",
                  "depends_on"
                ],
                "additionalProperties": true,
                "properties": {
                  "id": {
                    "type": "string"
                  },
                  "title": {
                    "type": "string"
                  },
                  "type": {
                    "enum": [
                      "spec",
                      "engineering",
                      "hotfix",
                      "adr"
                    ]
                  },
                  "status": {
                    "enum": [
                      "draft",
                      "proposed",
                      "approved",
                      "partial",
                      "implemented",
                      "verified",
                      "stale"
                    ]
                  },
                  "module": {
                    "type": "string"
                  },
                  "space": {
                    "enum": [
                      "repo",
                      "module",
                      "global"
                    ]
                  },
