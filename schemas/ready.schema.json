                      "path",
                      "heading"
                    ],
                    "properties": {
                      "path": {
                        "type": "string"
                      },
                      "heading": {
                        "type": "string"
                      },
                      "line": {
                        "type": "number"
                      },
                      "level": {
                        "type": "number"
                      },
                      "parent_headings": {
                        "type": "array",
                        "items": {
