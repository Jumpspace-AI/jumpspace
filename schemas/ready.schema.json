                  "spec": {
                    "type": "string"
                  },
                  "code": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "tests": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "gaps": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "depends_on": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            },
            "missingDependencies": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
