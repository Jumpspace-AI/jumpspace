{
  "contract_version": 1,
  "name": "ready",
  "command": "jumpspace ready --json",
  "description": "Approved or partial tasks ready for agent execution.",
  "schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": [
