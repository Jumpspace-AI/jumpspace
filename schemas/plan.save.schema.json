{
  "contract_version": 1,
  "name": "plan.save",
  "command": "jumpspace plan save <id> --file <plan-file> --json",
  "description": "Successful durable plan persistence result.",
  "schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": [
      "ok",
      "task_id",
      "plan"
    ],
    "additionalProperties": false,
    "properties": {
      "ok": {
        "const": true
      },
      "task_id": {
        "type": "string"
      },
      "plan": {
        "type": "object",
        "required": [
          "task_id",
          "goal",
          "status",
          "steps"
        ],
        "additionalProperties": true,
        "properties": {
          "task_id": {
            "type": "string"
          },
          "goal": {
            "type": "string"
          },
          "status": {
            "enum": [
              "pending",
              "in_progress",
              "complete",
              "blocked"
            ]
          },
          "steps": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "id",
                "outcome",
                "status",
                "depends_on",
                "source_files",
                "tests",
                "checks",
                "evidence"
              ],
              "additionalProperties": true,
              "properties": {
                "id": {
                  "type": "string"
                },
                "outcome": {
                  "type": "string"
                },
                "status": {
                  "enum": [
                    "pending",
                    "in_progress",
                    "complete",
                    "blocked"
                  ]
                },
                "depends_on": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "source_files": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "tests": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "checks": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "evidence": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
