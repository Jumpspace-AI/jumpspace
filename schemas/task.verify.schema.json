{
  "contract_version": 1,
  "name": "task.verify",
  "command": "jumpspace task verify <id> --check <cmd> --criteria <criterion-id> --json",
  "description": "Successful earned verification result with commit, checks, criteria coverage, and evidence.",
  "schema": {
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": [
      "ok",
      "task_id",
      "status",
      "record"
    ],
    "additionalProperties": false,
    "properties": {
      "ok": {
        "const": true
      },
      "task_id": {
        "type": "string"
      },
      "status": {
        "const": "verified"
      },
      "record": {
        "type": "object",
        "required": [
          "id",
          "verified_at",
          "commit",
          "checks",
          "acceptance_criteria_covered",
          "evidence"
        ],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string"
          },
          "verified_at": {
            "type": "string"
          },
          "commit": {
            "type": "string"
          },
          "checks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "command",
                "exit_code"
              ],
              "additionalProperties": false,
              "properties": {
                "command": {
                  "type": "string"
                },
                "exit_code": {
                  "type": "number"
                }
              }
            }
          },
          "acceptance_criteria_covered": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
